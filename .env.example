# OpenMantis environment variables
#
# Copy this file to `.env.local` and adjust values for your setup.

NODE_ENV=development

# Where OpenMantis stores cache data
OPENMANTIS_CACHE_DIR=.openmantis/cache

# Optional: runtime endpoints for local model servers
OPENMANTIS_RUNTIME_OLLAMA_URL=http://localhost:11434
OPENMANTIS_RUNTIME_FOUNDRY_URL=http://localhost:3000

# Token/context budgeting (defaults depend on runtime adapter)
OPENMANTIS_MAX_CONTEXT_TOKENS=4096
OPENMANTIS_MAX_OUTPUT_TOKENS=1024

# Logging verbosity
OPENMANTIS_VERBOSE=false

